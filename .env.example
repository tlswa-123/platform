# ============================================================
# WeCreat 环境变量配置
# ============================================================
#
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 根据注释填写对应的值
#   3. .env 已被 .gitignore 忽略，不会提交到仓库
#
# ============================================================

# ------------------------------------------------------------
# 运行环境（必填）
#   production  = 线上环境（使用 polaris 内网地址）
#   development = 本地开发环境（使用 office 地址）
# ------------------------------------------------------------
NODE_ENV=production

# ------------------------------------------------------------
# 服务端口（必填）
# ------------------------------------------------------------
PORT=3020

# ------------------------------------------------------------
# Adams API 配置（必填）
#
# ADAMS_API_BASE 会根据 NODE_ENV 自动选择：
#   production  -> 使用 ADAMS_API_BASE_ONLINE
#   development -> 使用 ADAMS_API_BASE_LOCAL
# 如果需要手动指定，取消注释 ADAMS_API_BASE 并填写地址即可覆盖。
# ------------------------------------------------------------
ADAMS_API_BASE_ONLINE=YOUR_ADAMS_API_BASE_ONLINE
ADAMS_API_BASE_LOCAL=YOUR_ADAMS_API_BASE_LOCAL
# ADAMS_API_BASE=                  # 手动覆盖（优先级最高，一般不需要设置）

ADAMS_BUSINESS=YOUR_ADAMS_BUSINESS
ADAMS_USER=YOUR_ADAMS_USER
ADAMS_TOKEN=YOUR_ADAMS_TOKEN

# ------------------------------------------------------------
# Claude Code Router（必填）
#   本地需要先启动 Claude Code Router 服务
# ------------------------------------------------------------
ANTHROPIC_BASE_URL=http://localhost:3456
ANTHROPIC_AUTH_TOKEN=test

# ------------------------------------------------------------
# ElevenLabs 音效生成（可选）
#   用于生成游戏音效，不配置则音效功能不可用
#   申请地址：https://elevenlabs.io
# ------------------------------------------------------------
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY

# ------------------------------------------------------------
# iChat 图片生成（可选）
#   用于 AI 图片生成，不配置则图片生成功能不可用
# ------------------------------------------------------------
# ICHAT_APPID=<你的 iChat AppID>
# ICHAT_APPKEY=<你的 iChat AppKey>
